{
  "name": "teamviewer-survey-app",
  "version": "1.0.0",
  "description": "TeamViewer利用状況アンケートシステム",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:frontend": "tsc -p tsconfig.frontend.json",
    "build:all": "npm run build && npm run build:frontend",
    "test": "jest",
    "test:property": "jest --testMatch='**/*.property.test.ts'",
    "test:coverage": "jest --coverage",
    "test:performance": "jest --testMatch='**/performance.test.ts' --runInBand",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf dist",
    "deploy:setup": "node -e \"process.platform === 'win32' ? require('child_process').execSync('powershell -File scripts/setup-ssm-parameters.ps1', {stdio: 'inherit'}) : require('child_process').execSync('bash scripts/setup-ssm-parameters.sh', {stdio: 'inherit'})\"",
    "deploy:validate": "node -e \"process.platform === 'win32' ? require('child_process').execSync('powershell -File scripts/validate.ps1', {stdio: 'inherit'}) : require('child_process').execSync('bash scripts/validate.sh', {stdio: 'inherit'})\"",
    "deploy:build": "npm run build:all && sam build",
    "deploy": "npm run deploy:build && sam deploy",
    "deploy:guided": "npm run deploy:build && sam deploy --guided",
    "deploy:full": "node -e \"process.platform === 'win32' ? require('child_process').execSync('powershell -File scripts/deploy.ps1', {stdio: 'inherit'}) : require('child_process').execSync('bash scripts/deploy.sh', {stdio: 'inherit'})\"",
    "deploy:full:guided": "node -e \"process.platform === 'win32' ? require('child_process').execSync('powershell -File scripts/deploy.ps1 -Guided', {stdio: 'inherit'}) : require('child_process').execSync('bash scripts/deploy.sh --guided', {stdio: 'inherit'})\"",
    "logs:auth": "sam logs -n AuthFunction --stack-name teamviewer-survey-app --tail",
    "logs:survey": "sam logs -n SurveyFunction --stack-name teamviewer-survey-app --tail",
    "logs:report": "sam logs -n ReportFunction --stack-name teamviewer-survey-app --tail",
    "logs:all": "sam logs --stack-name teamviewer-survey-app --tail"
  },
  "keywords": [
    "survey",
    "aws-lambda",
    "serverless",
    "teamviewer"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.490.0",
    "@aws-sdk/client-ssm": "^3.1001.0",
    "@aws-sdk/lib-dynamodb": "^3.490.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.131",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "aws-sdk-mock": "^5.9.0",
    "eslint": "^8.56.0",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}
