# 共通パスワード（一般ユーザー用）
COMMON_PASSWORD=your_common_password_here

# 管理者パスワード（karimata@okijoh.co.jp用）
ADMIN_PASSWORD=supervisor1!

# JWT署名用シークレット
JWT_SECRET=your_jwt_secret_here

# アンケート期間
SURVEY_START_DATE=2026-03-15
SURVEY_END_DATE=2026-06-27

# DynamoDBテーブル名
DYNAMODB_SESSIONS_TABLE=teamviewer-survey-sessions
DYNAMODB_RESPONSES_TABLE=teamviewer-survey-responses

# AWS設定（ローカル開発用）
AWS_REGION=ap-northeast-1
AWS_PROFILE=default
